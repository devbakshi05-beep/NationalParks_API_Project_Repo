<div class="row">
    <div class="col-9">
        <h2 class="text-primary">Trail List</h2>
    </div>
    <div class="col-3">
        <a asp-action="Upsert" class="btn btn-info form-control">
            <i fas fa-plus></i>&nbsp; Add New Trail
        </a>
    </div>
</div>

<div class="rounded table-bordered p-2 m-2">
    <table id="tblData" class="table table-active table-bordered table-hover table-striped">
        <thead>
            <tr>
                <th>National Park</th>
                <th>Trail Name</th>
                <th>Distance</th>
                <th>Elevation</th>
                <th>Actions</th>
            </tr>
        </thead>
    </table>
</div>
@section Scripts
{
    <script src="~/js/Trail.js"></script>
}